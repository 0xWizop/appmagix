rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // User settings (preferences, brand colors)
    match /user_settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Projects (Firestore mirror for analytics linking)
    match /projects/{projectId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Sites (connected for analytics)
    match /sites/{siteId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Analytics events — written by embed script (unauthenticated) or server
    match /analytics_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if true; // embed script posts anonymously
      allow update, delete: if false;
    }

    // Notifications — server creates, user reads/marks read
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, delete: if false;
    }

    // Intakes — server creates via Admin SDK
    match /intakes/{intakeId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if true; // public contact form
      allow update, delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
