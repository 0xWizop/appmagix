# Database
DATABASE_URL="postgresql://username:password@localhost:5432/merchantmagix?schema=public"

# NextAuth — URL must match your dev server (port 3001)
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
# NextAuth v5 also reads AUTH_SECRET if set
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (Email)
RESEND_API_KEY=""
EMAIL_FROM="MerchantMagix <noreply@merchantmagix.com>"

# Cron (weekly report) — set a secret and call GET /api/cron/weekly-report with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# App URL (for embed script, email links, etc.)
# Local: http://localhost:3001
# Production: https://merchantmagix.com
NEXT_PUBLIC_APP_URL="https://merchantmagix.com"

# Firebase (client — safe to expose in browser)
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyB_K-CBzKYvF6PLRQTUD9IoTHG6kgeM3x4"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="merchantmagix-5c6cd.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="merchantmagix-5c6cd"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="merchantmagix-5c6cd.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="720923064279"
NEXT_PUBLIC_FIREBASE_APP_ID="1:720923064279:web:7d074c77ac5ee0bb62bd92"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-YXH2H2N60N"

# Firebase Admin (server only). Use FB_ADMIN_ prefix (Firebase rejects FIREBASE_* in deploy).
# Option A: Path to service account JSON file
FB_ADMIN_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
# Option B: Individual env vars (required for Firebase Hosting deploy)
# FB_ADMIN_PROJECT_ID="merchantmagix-5c6cd"
# FB_ADMIN_CLIENT_EMAIL="..."
# FB_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
